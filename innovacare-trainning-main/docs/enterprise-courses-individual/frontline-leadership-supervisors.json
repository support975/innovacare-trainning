          "id": "expectations",
          "title": "Set Clear Expectations",
          "order": 1,
          "estMin": 15,
          "blocks": [
            {
              "id": "text",
              "type": "text",
              "html": "<p>Supervisors translate company goals into daily priorities. Clear expectations reduce confusion and make accountability fairer.</p>",
              "required": true
            }
          ]
        },
        {
          "id": "coach-feedback",
          "title": "Coach with Timely Feedback",
          "order": 2,
          "estMin": 15,
          "blocks": [
            {
              "id": "text",
              "type": "text",
              "html": "<p>Effective coaching is specific, timely, respectful, and connected to observable behavior.</p>",
              "required": true
            },
            {
              "id": "quiz",
              "type": "quiz",
              "mode": "single",
              "question": "Which feedback is most effective?",
              "required": true,
              "choices": [
                {
                  "id": "a",
                  "text": "You always do this wrong",
                  "correct": false
                },
                {
                  "id": "b",
                  "text": "In yesterday's report, two required fields were missing. Let's review the checklist.",
                  "correct": true
                },
                {
                  "id": "c",
                  "text": "No feedback until annual review",
                  "correct": false
                }
              ]
            }
          ]
        }
      ]
    },
    {
