              "html": "<p>Effective remote meetings have a purpose, agenda, owner, decisions, and documented next steps.</p>",
              "required": true
            },
            {
              "id": "quiz",
              "type": "quiz",
              "mode": "single",
              "question": "What makes a remote meeting more effective?",
              "required": true,
              "choices": [
                {
                  "id": "a",
                  "text": "No agenda and no follow-up",
                  "correct": false
                },
                {
                  "id": "b",
