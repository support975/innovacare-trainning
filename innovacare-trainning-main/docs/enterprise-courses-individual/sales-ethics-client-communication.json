      "id": "ethical-selling",
      "title": "Ethical Selling",
      "order": 1,
      "estMin": 22,
      "lessons": [
        {
          "id": "accuracy",
          "title": "Use Accurate Claims",
          "order": 1,
          "estMin": 11,
          "blocks": [
            {
              "id": "text",
              "type": "text",
              "html": "<p>Sales communication should be accurate, clear, and supported by approved materials. Avoid promises the company cannot deliver.</p>",
              "required": true
            }
          ]
        },
        {
          "id": "transparency",
          "title": "Transparency Builds Trust",
          "order": 2,
          "estMin": 11,
          "blocks": [
            {
              "id": "text",
              "type": "text",
              "html": "<p>Be clear about pricing, limitations, timelines, support, and contract terms. Escalate custom commitments before making promises.</p>",
              "required": true
            },
            {
              "id": "quiz",
              "type": "quiz",
              "mode": "single",
              "question": "What should a salesperson do before promising a custom feature or discount?",
              "required": true,
              "choices": [
                {
                  "id": "a",
                  "text": "Promise it immediately to close the deal",
                  "correct": false
                },
                {
                  "id": "b",
                  "text": "Confirm approval through the correct internal process",
                  "correct": true
                },
                {
                  "id": "c",
                  "text": "Avoid documenting it",
                  "correct": false
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "client-communication",
      "title": "Client Communication",
      "order": 2,
      "estMin": 23,
      "lessons": [
        {
          "id": "follow-up",
          "title": "Professional Follow-Up",
          "order": 1,
          "estMin": 11,
          "blocks": [
            {
              "id": "text",
              "type": "text",
              "html": "<p>Strong follow-up is timely, concise, and documents decisions, owners, and next steps.</p>",
              "required": true
            }
          ]
        },
        {
          "id": "records",
          "title": "Keep Clear Sales Records",
          "order": 2,
          "estMin": 12,
          "blocks": [
            {
              "id": "callout",
              "type": "callout",
              "style": "info",
              "html": "<p>Use the approved CRM or tracking system. Good records protect the client and the company.</p>",
              "required": true
            }
          ]
        }
      ]
    }
