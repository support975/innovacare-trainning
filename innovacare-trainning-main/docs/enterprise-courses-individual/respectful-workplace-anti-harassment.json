  "sections": [
    {
      "id": "respect",
      "title": "Respectful Conduct",
      "order": 1,
      "estMin": 30,
      "lessons": [
        {
          "id": "professional-behavior",
          "title": "Professional Behavior",
          "order": 1,
          "estMin": 15,
          "blocks": [
            {
              "id": "text",
              "type": "text",
              "html": "<p>Respectful workplaces are built through professional language, fair treatment, boundaries, inclusion, and accountability.</p>",
              "required": true
            }
          ]
        },
        {
          "id": "unacceptable-conduct",
          "title": "Recognize Unacceptable Conduct",
          "order": 2,
          "estMin": 15,
          "blocks": [
            {
              "id": "text",
              "type": "text",
              "html": "<p>Unacceptable conduct may include intimidation, insults, unwanted comments, retaliation, discriminatory behavior, or repeated disrespectful treatment.</p>",
              "required": true
            },
            {
              "id": "quiz",
              "type": "quiz",
              "mode": "single",
              "question": "Which behavior supports a respectful workplace?",
              "required": true,
              "choices": [
                {
                  "id": "a",
                  "text": "Retaliating against someone who reports a concern",
                  "correct": false
                },
                {
                  "id": "b",
                  "text": "Using respectful communication and reporting concerns appropriately",
                  "correct": true
                },
                {
                  "id": "c",
                  "text": "Ignoring repeated inappropriate comments",
                  "correct": false
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "reporting",
      "title": "Reporting and Bystander Responsibility",
      "order": 2,
      "estMin": 30,
      "lessons": [
        {
          "id": "bystander",
          "title": "Bystander Responsibility",
          "order": 1,
          "estMin": 15,
          "blocks": [
            {
              "id": "text",
              "type": "text",
              "html": "<p>Bystanders can support a respectful workplace by documenting concerns, checking on affected coworkers, and reporting through approved channels.</p>",
              "required": true
            }
          ]
        },
        {
          "id": "no-retaliation",
          "title": "No Retaliation",
          "order": 2,
          "estMin": 15,
          "blocks": [
            {
              "id": "callout",
              "type": "callout",
              "style": "warn",
              "html": "<p>Retaliation against someone who raises a good-faith concern should not be tolerated.</p>",
              "required": true
            }
          ]
        }
      ]
    }
