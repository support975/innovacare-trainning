        {
          "id": "why-sops-matter",
          "title": "Why SOPs Matter",
          "order": 1,
          "estMin": 12,
          "blocks": [
            {
              "id": "text",
              "type": "text",
              "html": "<p>Standard operating procedures reduce variation, support training, improve safety, and make quality easier to measure.</p>",
              "required": true
            }
          ]
        },
        {
          "id": "follow-procedure",
          "title": "Follow the Approved Procedure",
          "order": 2,
          "estMin": 13,
          "blocks": [
            {
              "id": "text",
              "type": "text",
              "html": "<p>Employees should use the current approved version, avoid shortcuts, and ask a supervisor when a procedure does not match the situation.</p>",
              "required": true
            },
            {
              "id": "quiz",
              "type": "quiz",
              "mode": "single",
              "question": "What should an employee do if an SOP seems outdated or unclear?",
              "required": true,
              "choices": [
                {
                  "id": "a",
                  "text": "Create an unofficial shortcut",
                  "correct": false
                },
                {
                  "id": "b",
                  "text": "Ask for clarification and report the issue through the approved process",
                  "correct": true
                },
                {
                  "id": "c",
                  "text": "Ignore the SOP completely",
                  "correct": false
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "quality-checks",
      "title": "Quality Checks",
      "order": 2,
      "estMin": 25,
      "lessons": [
        {
          "id": "document-results",
          "title": "Document Results",
          "order": 1,
          "estMin": 12,
          "blocks": [
            {
              "id": "text",
              "type": "text",
              "html": "<p>Good documentation makes work traceable. Record required checks accurately and at the time the work is performed.</p>",
              "required": true
            }
          ]
        },
        {
          "id": "continuous-improvement",
          "title": "Continuous Improvement",
          "order": 2,
